# ============================
# Canteen Management System — Environment Variables
# Duplicate this file as .env and fill in the values
# ============================

# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/canteen?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_long_random_string

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://yourapp.vercel.app

# Email (Gmail App Password — NOT your Gmail password)
# Create at: https://myaccount.google.com/apppasswords
EMAIL_FROM=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3000

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay (create at https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Sentry (optional — create at https://sentry.io)
SENTRY_DSN=https://xxxxxxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxxx
